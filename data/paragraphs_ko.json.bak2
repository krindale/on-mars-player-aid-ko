          ],
          "text_bbox": [
            2778,
            1674,
            3149,
            1776
          ],
          "text": "콜로니스트/고급 건물 마커가 있는 자기 광산 1개당 2 OP.",
          "style": "body_xs",
          "align": "left"
        },
        {
          "id": "p1_right_l_08",
