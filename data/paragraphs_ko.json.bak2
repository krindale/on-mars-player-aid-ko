          "text_bbox": [
            3164,
            1344,
            3983,
            1491
          ],
          "text": "과학자 카드 1장 채용 또는 지구 계약 1개(정상 비용).",
          "style": "body_xs",
          "align": "left"
        },
        {
          "id": "p1_right_r_08",
          "mask_bbox": [
            3152,
            1514,
            3972,
            1632
          ],
          "text_bbox": [
            3156,
            1518,
