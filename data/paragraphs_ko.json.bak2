            1629
          ],
          "text_bbox": [
            2793,
            1519,
            3152,
            1625
          ],
          "text": "화성에 보유한 고급 건물 마커 1개당 2 OP.",
          "style": "body_xs",
          "align": "left"
        },
        {
          "id": "p1_right_l_07",
          "mask_bbox": [
            2774,
