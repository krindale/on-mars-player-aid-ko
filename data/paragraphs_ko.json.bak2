          ],
          "text_bbox": [
            2807,
            2145,
            3149,
            2236
          ],
          "text": "화성에 보유한 자기 셸터 1개당 2 OP.",
          "style": "body_xs",
          "align": "left"
        },
        {
          "id": "p1_right_l_11",
          "mask_bbox": [
            2784,
